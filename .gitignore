# Ignore everything by default
*

# Keep git control files
!.gitignore

# Keep deployment/runtime files
!README.md
!.env.example
!.python-version
!requirements.txt
!vercel.json

# Keep Vercel-native app
!api/
!api/**
api/**/__pycache__/
api/**/*.pyc

# Keep separate Render inference service
!inference_service/
!inference_service/**
inference_service/**/__pycache__/
inference_service/**/*.pyc

# Keep local parser package used by backend
!fashn_human_parser/
!fashn_human_parser/**
fashn_human_parser/**/__pycache__/
fashn_human_parser/**/*.pyc

# Keep required model assets
!work/
!work/model_out/
!work/model_out/pca_v2.joblib
!work/model_out/mlp.pt
!work/model_out/mlp_numpy.npz

# Never commit secrets or local vercel metadata
.env
.env.*
.vercel/
